---

---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover" />
		<title>Hey, Hilton</title>
		<style>
			* { margin: 0; padding: 0; box-sizing: border-box; }
			html, body { height: 100%; }
			body { overflow: hidden; background: #fff; color-scheme: light dark; -webkit-user-select: none; user-select: none; -webkit-touch-callout: none; }
			@media (prefers-color-scheme: dark) { body { background: #000; } }
			canvas { display: block; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; height: 100dvh; touch-action: none; }
		</style>
	</head>
	<body>
		<canvas id="c"></canvas>
		<script>
			const canvas = document.getElementById('c') as HTMLCanvasElement;
			const ctx = canvas.getContext('2d')!;
			const dpr = devicePixelRatio;

			function resize() {
				canvas.width = window.innerWidth * dpr;
				canvas.height = window.innerHeight * dpr;
				ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
			}
			window.addEventListener('resize', resize);
			resize();

			const W = () => window.innerWidth;
			const H = () => window.innerHeight;

			const T = 80 * 52;
			const s = new Date(1982, 2, 17);
			const elapsed = Math.floor((Date.now() - s.getTime()) / (7 * 24 * 60 * 60 * 1000));
			const N = Math.max(0, T - elapsed);

			const attractors = [
				{ x: 0.3, y: 0.4, strength: 500 },
				{ x: 0.7, y: 0.6, strength: 400 },
				{ x: 0.5, y: 0.2, strength: 350 },
				{ x: 0.2, y: 0.8, strength: 300 },
				{ x: 0.8, y: 0.3, strength: 380 },
			];

			interface Particle {
				x: number;
				y: number;
				vx: number;
				vy: number;
				size: number;
				mark: boolean;
			}

			const particles: Particle[] = [];
			for (let i = 0; i < N; i++) {
				particles.push({
					x: Math.random() * W(),
					y: Math.random() * H(),
					vx: (Math.random() - 0.5) * 2,
					vy: (Math.random() - 0.5) * 2,
					size: Math.random() * 2.5 + 1,
					mark: i === 0,
				});
			}

			const dark = matchMedia('(prefers-color-scheme: dark)').matches;
			const particleColor = dark ? '#fff' : '#000';
			const markColor = dark ? '#f44' : '#e00';

			let mx = -9999;
			let my = -9999;

			document.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; });
			document.addEventListener('mouseleave', () => { mx = -9999; my = -9999; });
			document.addEventListener('touchmove', e => { e.preventDefault(); mx = e.touches[0].clientX; my = e.touches[0].clientY; }, { passive: false });
			document.addEventListener('touchstart', e => { mx = e.touches[0].clientX; my = e.touches[0].clientY; });
			document.addEventListener('touchend', () => { mx = -9999; my = -9999; });

			const CELL = 12;
			const MAX_SPEED = 6;
			const MAX_CELLS = 300 * 200;
			const gridHead = new Int32Array(MAX_CELLS).fill(-1);
			const gridNext = new Int32Array(N).fill(-1);

			function frame() {
				const w = W();
				const h = H();
				ctx.clearRect(0, 0, w, h);

				const cols = (w / CELL | 0) + 1;
				const rows = (h / CELL | 0) + 1;
				const totalCells = cols * rows;
				for (let i = 0; i < totalCells; i++) gridHead[i] = -1;

				for (let i = 0; i < N; i++) {
					const p = particles[i];
					const key = (p.x / CELL | 0) + (p.y / CELL | 0) * cols;
					if (key >= 0 && key < totalCells) {
						gridNext[i] = gridHead[key];
						gridHead[key] = i;
					} else {
						gridNext[i] = -1;
					}
				}

				let marked: Particle | null = null;
				for (let i = 0; i < N; i++) {
					const p = particles[i];
					const cx = p.x / CELL | 0;
					const cy = p.y / CELL | 0;
					for (let dy = -1; dy <= 1; dy++) {
						const ny = cy + dy;
						if (ny < 0 || ny >= rows) continue;
						for (let dx = -1; dx <= 1; dx++) {
							const nx = cx + dx;
							if (nx < 0 || nx >= cols) continue;
							let j = gridHead[nx + ny * cols];
							while (j !== -1) {
								if (j !== i) {
									const q = particles[j];
									const rx = p.x - q.x;
									const ry = p.y - q.y;
									const d = rx * rx + ry * ry;
									if (d < 16 && d > 0.1) {
										const f = 0.3 / d;
										p.vx += rx * f;
										p.vy += ry * f;
									}
								}
								j = gridNext[j];
							}
						}
					}

					for (const a of attractors) {
						const ax = a.x * w;
						const ay = a.y * h;
						const adx = ax - p.x;
						const ady = ay - p.y;
						const dist = Math.sqrt(adx * adx + ady * ady) + 1;
						const f = a.strength / (dist * dist);
						p.vx += (-ady * f + adx * f * 0.3) * 0.01;
						p.vy += (adx * f + ady * f * 0.3) * 0.01;
					}

					const mdx = p.x - mx;
					const mdy = p.y - my;
					const mDist = Math.sqrt(mdx * mdx + mdy * mdy) + 1;
					if (mDist < 150) {
						const mf = 800 / (mDist * mDist);
						p.vx += mdx * mf;
						p.vy += mdy * mf;
					}

					p.vx *= 0.98;
					p.vy *= 0.98;

					const speed = Math.sqrt(p.vx * p.vx + p.vy * p.vy);
					if (speed > MAX_SPEED) {
						p.vx = (p.vx / speed) * MAX_SPEED;
						p.vy = (p.vy / speed) * MAX_SPEED;
					}

					p.x += p.vx;
					p.y += p.vy;

					if (p.x < -10) p.x = w + 10;
					if (p.x > w + 10) p.x = -10;
					if (p.y < -10) p.y = h + 10;
					if (p.y > h + 10) p.y = -10;

					if (p.mark) { marked = p; continue; }
					ctx.fillStyle = particleColor;
					ctx.fillRect(p.x | 0, p.y | 0, p.size | 0, p.size | 0);
				}

				if (marked) {
					ctx.fillStyle = markColor;
					const sz = (marked.size | 0) + 3;
					ctx.fillRect(marked.x | 0, marked.y | 0, sz, sz);
				}

				requestAnimationFrame(frame);
			}
			requestAnimationFrame(frame);
		</script>
	</body>
</html>
